# Database
DATABASE_URL=sqlite:///.\pcdealtracker.db
# For PostgreSQL: postgresql://user:password@localhost/pcdealtracker

# Redis / cache
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=False

# Scraping settings
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_SCRAPERS=3
REQUEST_DELAY_SECONDS=2

# API settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=release
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs\pcdealtracker.log

# Security
SECRET_KEY=change-me
